@page "/webhooks"
@layout AppLayout

@inject ApiClient Api
@inject AuthService AuthSvc

<PageTitle>Webhooks — NiagaOne</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Webhooks</h1>
        <div class="page-sub">View webhook subscriptions and event callbacks</div>
    </div>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading webhooks...</div>
}
else
{
    <div class="card">
        <div style="padding:.75rem 1rem;display:flex;gap:.75rem;align-items:center">
            <input class="form-control-custom" placeholder="Search webhooks..." @bind="_search" @bind:event="oninput" @onkeydown="HandleSearchKey" style="max-width:300px" />
            <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" @onclick="SearchAsync">Search</button>
        </div>
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Entity Type</th>
                        <th>Event Type</th>
                        <th>Callback URL</th>
                        <th>Active</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_pagedResult == null || !_pagedResult.Items.Any())
                    {
                        <tr><td colspan="5">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#128279;</div>
                                <div class="empty-state-text">No webhooks found.</div>
                            </div>
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var w in _pagedResult.Items)
                        {
                            <tr>
                                <td><strong>@w.Name</strong></td>
                                <td>@w.EntityType</td>
                                <td>@w.EventType</td>
                                <td style="color:#64748b;font-size:.85rem;max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@w.CallbackUrl</td>
                                <td><span class="badge-status @(w.IsActive ? "status-active" : "status-inactive")">@(w.IsActive ? "Active" : "Inactive")</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (_pagedResult != null && _pagedResult.TotalPages > 1)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;border-top:1px solid var(--border)">
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasPreviousPage)" @onclick="PrevPage">Previous</button>
                <span style="font-size:.85rem;color:var(--text-muted)">Page @_pagedResult.Page of @_pagedResult.TotalPages</span>
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasNextPage)" @onclick="NextPage">Next</button>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private string _search = string.Empty;
    private int _page = 1;
    private int _pageSize = 20;
    private PagedResult<WebhookSubscriptionDto>? _pagedResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        _loading = false;
    }

    private async Task LoadDataAsync()
    {
        try { _pagedResult = await Api.GetWebhooksAsync(_page, _pageSize, _search); } catch { }
    }

    private async Task SearchAsync() { _page = 1; await LoadDataAsync(); }
    private async Task HandleSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") await SearchAsync(); }
    private async Task PrevPage() { _page--; await LoadDataAsync(); }
    private async Task NextPage() { _page++; await LoadDataAsync(); }
}
