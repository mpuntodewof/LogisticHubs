@page "/settings"
@layout AppLayout

@inject ApiClient Api
@inject AuthService AuthSvc

<PageTitle>Settings — NiagaOne</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Tenant Settings</h1>
        <div class="page-sub">View and manage system configuration</div>
    </div>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading settings...</div>
}
else
{
    <div class="card">
        <div style="padding:.75rem 1rem;display:flex;gap:.75rem;align-items:center">
            <input class="form-control-custom" placeholder="Search settings..." @bind="_search" @bind:event="oninput" @onkeydown="HandleSearchKey" style="max-width:300px" />
            <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" @onclick="SearchAsync">Search</button>
        </div>
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Key</th>
                        <th>Value</th>
                        <th>Group</th>
                        <th>Type</th>
                        <th>Read Only</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (_pagedResult == null || !_pagedResult.Items.Any())
                    {
                        <tr><td colspan="6">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#9881;</div>
                                <div class="empty-state-text">No settings found.</div>
                            </div>
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var s in _pagedResult.Items)
                        {
                            <tr>
                                <td><strong>@s.Key</strong></td>
                                <td>
                                    @if (_editingId == s.Id)
                                    {
                                        <input class="form-control-custom" style="padding:.25rem .5rem;font-size:.85rem" @bind="_editValue" />
                                    }
                                    else
                                    {
                                        <span style="color:#64748b">@(s.Value ?? "—")</span>
                                    }
                                </td>
                                <td>@(s.Group ?? "—")</td>
                                <td>@s.ValueType</td>
                                <td>
                                    @if (s.IsReadOnly)
                                    {
                                        <span class="badge-status status-admin">Read Only</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status status-active">Editable</span>
                                    }
                                </td>
                                <td>
                                    @if (!s.IsReadOnly)
                                    {
                                        @if (_editingId == s.Id)
                                        {
                                            <div style="display:flex;gap:.3rem;justify-content:flex-end">
                                                <button class="btn-primary-custom" style="padding:.3rem .7rem;font-size:.75rem" @onclick="() => SaveAsync(s)" disabled="@_saving">Save</button>
                                                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.75rem" @onclick="CancelEdit">Cancel</button>
                                            </div>
                                        }
                                        else
                                        {
                                            <button class="btn-outline" style="padding:.3rem .7rem;font-size:.75rem" @onclick="() => StartEdit(s)">Edit</button>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (_pagedResult != null && _pagedResult.TotalPages > 1)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;border-top:1px solid var(--border)">
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasPreviousPage)" @onclick="PrevPage">Previous</button>
                <span style="font-size:.85rem;color:var(--text-muted)">Page @_pagedResult.Page of @_pagedResult.TotalPages</span>
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasNextPage)" @onclick="NextPage">Next</button>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private bool _saving;
    private string _search = string.Empty;
    private int _page = 1;
    private int _pageSize = 20;
    private PagedResult<TenantSettingDto>? _pagedResult;
    private Guid? _editingId;
    private string _editValue = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        _loading = false;
    }

    private async Task LoadDataAsync()
    {
        try { _pagedResult = await Api.GetTenantSettingsAsync(_page, _pageSize, _search); } catch { }
    }

    private async Task SearchAsync() { _page = 1; await LoadDataAsync(); }
    private async Task HandleSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") await SearchAsync(); }
    private async Task PrevPage() { _page--; await LoadDataAsync(); }
    private async Task NextPage() { _page++; await LoadDataAsync(); }

    private void StartEdit(TenantSettingDto s)
    {
        _editingId = s.Id;
        _editValue = s.Value ?? string.Empty;
    }

    private void CancelEdit()
    {
        _editingId = null;
        _editValue = string.Empty;
    }

    private async Task SaveAsync(TenantSettingDto s)
    {
        _saving = true;
        var ok = await Api.UpdateTenantSettingAsync(s.Id, new { Value = _editValue });
        if (ok)
        {
            _editingId = null;
            await LoadDataAsync();
        }
        _saving = false;
    }
}
