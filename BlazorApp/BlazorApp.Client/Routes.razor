<Router AppAssembly="typeof(BlazorApp.Client._Imports).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(BlazorApp.Client.Layout.AuthLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(BlazorApp.Client.Layout.AuthLayout)">
            <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;text-align:center">
                <div style="font-size:4rem;margin-bottom:1rem">&#128533;</div>
                <h1 style="font-size:1.5rem;color:#fff">Page Not Found</h1>
                <p style="color:#94a3b8">The page you're looking for doesn't exist.</p>
                <a href="/" class="btn-primary-custom" style="text-decoration:none;margin-top:1rem">Go to Dashboard</a>
            </div>
        </LayoutView>
    </NotFound>
</Router>
