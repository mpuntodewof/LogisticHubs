@page "/stock-movements"
@layout AppLayout
@using System.Text.Json

@inject ApiClient Api
@inject NavigationManager Nav
@inject AuthService AuthSvc

<PageTitle>Stock Movements — NiagaOne</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Stock Movements</h1>
        <div class="page-sub">Track inventory changes across warehouses</div>
    </div>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert-custom alert-error" style="margin-bottom:1rem">
        &#9888; @_error
        <button style="float:right;background:none;border:none;cursor:pointer;font-size:1rem" @onclick="() => _error = string.Empty">&times;</button>
    </div>
}

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading stock movements...</div>
}
else
{
    <div class="card">
        <div style="padding:.75rem 1rem;display:flex;gap:.75rem;align-items:center">
            <input class="form-control-custom" placeholder="Search movements..." @bind="_search" @bind:event="oninput" @onkeydown="HandleSearchKey" style="max-width:300px" />
            <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" @onclick="SearchAsync">Search</button>
        </div>
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Warehouse</th>
                        <th>SKU</th>
                        <th>Type</th>
                        <th>Reason</th>
                        <th>Quantity</th>
                        <th>Before</th>
                        <th>After</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_pagedResult == null || !_pagedResult.Items.Any())
                    {
                        <tr><td colspan="8">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#128259;</div>
                                <div class="empty-state-text">No stock movements found.</div>
                            </div>
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var item in _pagedResult.Items)
                        {
                            var movementType = GetVal(item, "movementType");
                            <tr>
                                <td><strong>@GetVal(item, "warehouseName")</strong></td>
                                <td>@GetVal(item, "sku")</td>
                                <td><span class="badge-status @TypeClass(movementType)">@movementType</span></td>
                                <td>@GetVal(item, "reason")</td>
                                <td>@GetVal(item, "quantity")</td>
                                <td>@GetVal(item, "quantityBefore")</td>
                                <td>@GetVal(item, "quantityAfter")</td>
                                <td>@FormatDate(GetVal(item, "createdAt"))</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (_pagedResult != null && _pagedResult.TotalPages > 1)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;border-top:1px solid var(--border)">
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasPreviousPage)" @onclick="PrevPage">Previous</button>
                <span style="font-size:.85rem;color:var(--text-muted)">Page @_pagedResult.Page of @_pagedResult.TotalPages</span>
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasNextPage)" @onclick="NextPage">Next</button>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private string _search = string.Empty;
    private string _error = string.Empty;
    private int _page = 1;
    private int _pageSize = 20;
    private PagedResult<JsonElement>? _pagedResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        _loading = false;
    }

    private async Task LoadDataAsync()
    {
        _error = string.Empty;
        var result = await Api.GetStockMovementsAsync(_page, _pageSize, _search);
        if (result.Success)
        {
            _pagedResult = result.Data;
        }
        else if (result.IsServerError)
        {
            _error = "Something went wrong. Please try again.";
        }
        else
        {
            _error = result.ErrorMessage ?? "Failed to load stock movements.";
        }
    }

    private async Task SearchAsync()
    {
        _page = 1;
        await LoadDataAsync();
    }

    private async Task HandleSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    private async Task PrevPage() { _page--; await LoadDataAsync(); }
    private async Task NextPage() { _page++; await LoadDataAsync(); }

    private const string Dash = "—";

    private static string GetVal(JsonElement element, string key)
    {
        if (element.ValueKind != JsonValueKind.Object) return Dash;
        if (!element.TryGetProperty(key, out var prop)) return Dash;
        return prop.ValueKind switch
        {
            JsonValueKind.Null or JsonValueKind.Undefined => Dash,
            JsonValueKind.String => prop.GetString() ?? Dash,
            JsonValueKind.Number => prop.ToString(),
            JsonValueKind.True => "true",
            JsonValueKind.False => "false",
            _ => prop.ToString()
        };
    }

    private static string TypeClass(string t) => "status-" + t.ToLower().Replace(" ", "");

    private static string FormatDate(string raw)
    {
        if (raw == Dash || string.IsNullOrWhiteSpace(raw)) return Dash;
        return DateTime.TryParse(raw, out var dt) ? dt.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : raw;
    }
}
