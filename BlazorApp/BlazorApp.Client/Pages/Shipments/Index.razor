@page "/shipments"
@layout AppLayout

@inject ApiClient Api
@inject NavigationManager Nav
@inject AuthService AuthSvc

<PageTitle>Shipments — NiagaOne</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Shipments</h1>
        <div class="page-sub">Track and manage all shipments</div>
    </div>
    <button class="btn-primary-custom" @onclick="() => _showCreate = true">
        &#43; New Shipment
    </button>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading shipments...</div>
}
else
{
    <div class="card">
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Tracking No.</th>
                        <th>Destination</th>
                        <th>Weight (kg)</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_shipments.Any())
                    {
                        <tr><td colspan="6">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#128230;</div>
                                <div class="empty-state-text">No shipments found. Create your first one.</div>
                            </div>
                        </td></tr>
                    }
                    @foreach (var s in _shipments)
                    {
                        <tr>
                            <td><strong>@s.TrackingNumber</strong></td>
                            <td>@s.DestinationAddress</td>
                            <td>@s.Weight.ToString("F1")</td>
                            <td><span class="badge-status @StatusClass(s.Status)">@s.Status</span></td>
                            <td>@s.CreatedAt.ToString("MMM d, yyyy")</td>
                            <td>
                                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.75rem" @onclick="@(() => Nav.NavigateTo("/shipments/" + s.Id))">
                                    View
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_showCreate)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;display:flex;align-items:center;justify-content:center">
        <div class="card" style="width:460px;max-width:95vw">
            <div class="card-header-custom">
                <span class="card-title-custom">New Shipment</span>
                <button class="btn-logout" @onclick="() => _showCreate = false">&#x2715;</button>
            </div>
            <div class="card-body-custom">
                @if (!string.IsNullOrEmpty(_createError))
                {
                    <div class="alert-custom alert-error">&#9888; @_createError</div>
                }
                <div class="form-group">
                    <label class="form-label">Origin Warehouse</label>
                    <select class="form-control-custom" @bind="_newShipment.OriginWarehouseId">
                        <option value="@Guid.Empty">-- Select Warehouse --</option>
                        @foreach (var w in _warehouses)
                        {
                            <option value="@w.Id">@w.Name (@w.Location)</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Destination Address</label>
                    <input class="form-control-custom" @bind="_newShipment.DestinationAddress" placeholder="123 Main St, City" />
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">
                    <div class="form-group">
                        <label class="form-label">Weight (kg)</label>
                        <input class="form-control-custom" type="number" @bind="_newShipment.Weight" placeholder="0.00" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Volume (m³)</label>
                        <input class="form-control-custom" type="number" @bind="_newShipment.Volume" placeholder="0.00" />
                    </div>
                </div>
                <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem">
                    <button class="btn-outline" @onclick="() => _showCreate = false">Cancel</button>
                    <button class="btn-primary-custom" @onclick="CreateShipmentAsync" disabled="@_creating">
                        @if (_creating) { <span class="spinner" style="border-top-color:#fff"></span> }
                        Create
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _showCreate;
    private bool _creating;
    private string _createError = string.Empty;
    private List<ShipmentDto> _shipments = new();
    private List<WarehouseDto> _warehouses = new();
    private readonly CreateShipmentRequest _newShipment = new();

    protected override async Task OnInitializedAsync()
    {
        try { _shipments = await Api.GetShipmentsAsync(); } catch { }
        try { _warehouses = await Api.GetWarehousesAsync(); } catch { }

        _loading = false;
    }

    private async Task CreateShipmentAsync()
    {
        _creating = true;
        _createError = string.Empty;

        var result = await Api.CreateShipmentAsync(_newShipment);
        if (result != null)
        {
            _shipments.Insert(0, result);
            _showCreate = false;
        }
        else
        {
            _createError = "Failed to create shipment. Check the warehouse ID.";
        }

        _creating = false;
    }

    private static string StatusClass(string s) => "status-" + s.ToLower().Replace(" ", "");
}
