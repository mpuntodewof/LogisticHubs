@page "/invoices"
@layout AppLayout

@inject ApiClient Api
@inject NavigationManager Nav
@inject AuthService AuthSvc

<PageTitle>Invoices — NiagaOne</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Invoices</h1>
        <div class="page-sub">View and track all invoices</div>
    </div>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert-custom alert-error" style="margin-bottom:1rem">
        &#9888; @_error
        <button style="float:right;background:none;border:none;cursor:pointer;font-size:1rem" @onclick="() => _error = string.Empty">&times;</button>
    </div>
}

@* ── Search ── *@
<div class="card" style="margin-bottom:1rem;padding:1rem">
    <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center">
        <div class="form-group" style="margin:0;flex:1;min-width:200px">
            <input class="form-control-custom" placeholder="Search by invoice number..." @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
        </div>
    </div>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading invoices...</div>
}
else
{
    <div class="card">
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Invoice #</th>
                        <th>Status</th>
                        <th>Due Date</th>
                        <th>Grand Total</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_items == null || !_items.Any())
                    {
                        <tr><td colspan="5">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#128196;</div>
                                <div class="empty-state-text">No invoices found.</div>
                            </div>
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var inv in _items)
                        {
                            <tr>
                                <td><strong>@inv.InvoiceNumber</strong></td>
                                <td><span class="badge-status @StatusClass(inv.Status)">@inv.Status</span></td>
                                <td>@inv.DueDate.ToString("MMM d, yyyy")</td>
                                <td>@($"Rp {inv.GrandTotal:N0}")</td>
                                <td>@inv.CreatedAt.ToString("MMM d, yyyy")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* ── Pagination ── *@
        @if (_totalPages > 1)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:1rem;border-top:1px solid #e2e8f0">
                <span style="font-size:.85rem;color:#64748b">Page @_page of @_totalPages (@_totalCount total)</span>
                <div style="display:flex;gap:.5rem">
                    <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" disabled="@(!_hasPrevious)" @onclick="PreviousPage">Previous</button>
                    <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" disabled="@(!_hasNext)" @onclick="NextPage">Next</button>
                </div>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private string _search = string.Empty;
    private string _error = string.Empty;

    private List<InvoiceDto> _items = new();

    private int _page = 1;
    private int _pageSize = 20;
    private int _totalCount;
    private int _totalPages;
    private bool _hasPrevious;
    private bool _hasNext;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = string.Empty;
        var result = await Api.GetInvoicesAsync(_page, _pageSize, string.IsNullOrWhiteSpace(_search) ? null : _search.Trim());
        if (result.Success && result.Data != null)
        {
            _items = result.Data.Items;
            _totalCount = result.Data.TotalCount;
            _totalPages = result.Data.TotalPages;
            _hasPrevious = result.Data.HasPreviousPage;
            _hasNext = result.Data.HasNextPage;
        }
        else
        {
            _error = result.IsServerError ? "Something went wrong. Please try again." : (result.ErrorMessage ?? "Failed to load invoices.");
        }
        _loading = false;
    }

    private async Task OnSearchKeyUp(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task PreviousPage() { if (_hasPrevious) { _page--; await LoadAsync(); } }
    private async Task NextPage() { if (_hasNext) { _page++; await LoadAsync(); } }

    private static string StatusClass(string s) => "status-" + s.ToLower().Replace(" ", "");
}
