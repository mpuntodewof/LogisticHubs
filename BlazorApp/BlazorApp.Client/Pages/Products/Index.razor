@page "/products"
@layout AppLayout

@inject ApiClient Api
@inject NavigationManager Nav
@inject AuthService AuthSvc
@inject AuthenticationStateProvider AuthState

<PageTitle>Products — StockLedger</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Products</h1>
        <div class="page-sub">Product catalog management</div>
    </div>
    <button class="btn-primary-custom" @onclick="OpenCreate">
        &#43; New Product
    </button>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading products...</div>
}
else
{
    <div class="card">
        <div style="padding:.75rem 1rem;display:flex;gap:.75rem;align-items:center">
            <input class="form-control-custom" placeholder="Search products..." @bind="_search" @bind:event="oninput" @onkeydown="HandleSearchKey" style="max-width:300px" />
            <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" @onclick="SearchAsync">Search</button>
        </div>
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Brand</th>
                        <th>Status</th>
                        <th>Variants</th>
                        <th>Created</th>
                        @if (_canUpdate || _canDelete)
                        {
                            <th style="width:90px">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (_pagedResult == null || !_pagedResult.Items.Any())
                    {
                        <tr><td colspan="@(_canUpdate || _canDelete ? 7 : 6)">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#128230;</div>
                                <div class="empty-state-text">No products found.</div>
                            </div>
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var p in _pagedResult.Items)
                        {
                            <tr>
                                <td><strong>@p.Name</strong></td>
                                <td>@p.CategoryName</td>
                                <td>@(p.BrandName ?? "—")</td>
                                <td><span class="badge-status @StatusClass(p.Status)">@p.Status</span></td>
                                <td>@p.VariantCount</td>
                                <td>@p.CreatedAt.ToString("MMM d, yyyy")</td>
                                @if (_canUpdate || _canDelete)
                                {
                                    <td>
                                        <div class="row-actions">
                                            @if (_canUpdate)
                                            {
                                                <button class="btn-icon" title="Edit" @onclick="() => OpenEdit(p)">&#9998;</button>
                                            }
                                            @if (_canDelete)
                                            {
                                                <button class="btn-icon btn-icon-danger" title="Delete" @onclick="() => ConfirmDelete(p)">&#128465;</button>
                                            }
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (_pagedResult != null && _pagedResult.TotalPages > 1)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;border-top:1px solid var(--border)">
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasPreviousPage)" @onclick="PrevPage">Previous</button>
                <span style="font-size:.85rem;color:var(--text-muted)">Page @_pagedResult.Page of @_pagedResult.TotalPages</span>
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasNextPage)" @onclick="NextPage">Next</button>
            </div>
        }
    </div>
}

@* ── Create / Edit Modal ── *@
@if (_showModal)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;display:flex;align-items:center;justify-content:center">
        <div class="card" style="width:460px;max-width:95vw">
            <div class="card-header-custom">
                <span class="card-title-custom">@(_editId == null ? "New Product" : "Edit Product")</span>
                <button class="btn-logout" @onclick="CloseModal">&#x2715;</button>
            </div>
            <div class="card-body-custom">
                @if (!string.IsNullOrEmpty(_modalError))
                {
                    <div class="alert-custom alert-error">&#9888; @_modalError</div>
                }
                <div class="form-group">
                    <label class="form-label">Name</label>
                    <input class="form-control-custom" @bind="_formItem.Name" placeholder="Product name" />
                </div>
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <input class="form-control-custom" @bind="_formItem.Description" placeholder="Optional description" />
                </div>
                <div class="form-group">
                    <label class="form-label">Category</label>
                    <select class="form-control-custom" @bind="_formItem.CategoryId">
                        <option value="@Guid.Empty">-- Select Category --</option>
                        @if (_categories != null)
                        {
                            @foreach (var c in _categories.Items)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Brand</label>
                    <select class="form-control-custom" @bind="_formItem.BrandId">
                        <option value="">-- None --</option>
                        @if (_brands != null)
                        {
                            @foreach (var b in _brands.Items)
                            {
                                <option value="@b.Id">@b.Name</option>
                            }
                        }
                    </select>
                </div>
                <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem">
                    <button class="btn-outline" @onclick="CloseModal">Cancel</button>
                    <button class="btn-primary-custom" @onclick="SaveAsync" disabled="@_saving">
                        @if (_saving) { <span class="spinner" style="border-top-color:#fff"></span> }
                        @(_editId == null ? "Create" : "Save Changes")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Delete Confirmation Dialog ── *@
@if (_showDeleteDialog)
{
    <div class="dialog-overlay">
        <div class="dialog-card">
            <div class="dialog-icon">&#128465;</div>
            <div class="dialog-title">Delete Product</div>
            <div class="dialog-message">Are you sure you want to delete <strong>@_deleteTarget?.Name</strong>? This action cannot be undone.</div>
            <div class="dialog-actions">
                <button class="btn-outline" @onclick="() => _showDeleteDialog = false">Cancel</button>
                <button class="btn-danger" @onclick="DeleteAsync" disabled="@_deleting">
                    @if (_deleting) { <span class="spinner" style="border-top-color:#fff"></span> }
                    Delete
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _showModal;
    private bool _saving;
    private bool _showDeleteDialog;
    private bool _deleting;
    private Guid? _editId;
    private string _modalError = string.Empty;
    private string _search = string.Empty;
    private int _page = 1;
    private int _pageSize = 20;
    private bool _canUpdate, _canDelete;
    private PagedResult<ProductDto>? _pagedResult;
    private PagedResult<CategoryDto>? _categories;
    private PagedResult<BrandDto>? _brands;
    private CreateProductRequest _formItem = new();
    private ProductDto? _deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var perms = state.User.Claims.Where(c => c.Type == "permissions").Select(c => c.Value).ToHashSet();
        _canUpdate = perms.Contains("products.update");
        _canDelete = perms.Contains("products.delete");

        var catResult = await Api.GetCategoriesAsync(1, 100, null); if (catResult.Success) _categories = catResult.Data;
        var brdResult = await Api.GetBrandsAsync(1, 100, null); if (brdResult.Success) _brands = brdResult.Data;
        await LoadDataAsync();
        _loading = false;
    }

    private async Task LoadDataAsync()
    {
        var apiResult = await Api.GetProductsAsync(_page, _pageSize, _search); if (apiResult.Success) _pagedResult = apiResult.Data;
    }

    private async Task SearchAsync() { _page = 1; await LoadDataAsync(); }
    private async Task HandleSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") await SearchAsync(); }
    private async Task PrevPage() { _page--; await LoadDataAsync(); }
    private async Task NextPage() { _page++; await LoadDataAsync(); }

    private void OpenCreate()
    {
        _editId = null;
        _formItem = new();
        _modalError = string.Empty;
        _showModal = true;
    }

    private void OpenEdit(ProductDto p)
    {
        _editId = p.Id;
        _formItem = new CreateProductRequest
        {
            Name = p.Name,
            Description = p.Description,
            CategoryId = p.CategoryId,
            BrandId = p.BrandId
        };
        _modalError = string.Empty;
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _editId = null;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _modalError = string.Empty;

        bool success;
        string? errorMessage;

        if (_editId == null)
        {
            var result = await Api.CreateProductAsync(_formItem);
            success = result.Success;
            errorMessage = result.ErrorMessage;
        }
        else
        {
            var result = await Api.UpdateProductAsync(_editId.Value, _formItem);
            success = result.Success;
            errorMessage = result.ErrorMessage;
        }

        if (success)
        {
            CloseModal();
            await LoadDataAsync();
        }
        else
        {
            _modalError = errorMessage ?? (_editId == null ? "Failed to create product." : "Failed to update product.");
        }

        _saving = false;
    }

    private void ConfirmDelete(ProductDto p)
    {
        _deleteTarget = p;
        _showDeleteDialog = true;
    }

    private async Task DeleteAsync()
    {
        if (_deleteTarget == null) return;
        _deleting = true;

        var result = await Api.DeleteProductAsync(_deleteTarget.Id);
        if (result.Success)
        {
            _showDeleteDialog = false;
            _deleteTarget = null;
            await LoadDataAsync();
        }
        else
        {
            _showDeleteDialog = false;
            _modalError = result.ErrorMessage ?? "Failed to delete product.";
        }

        _deleting = false;
    }

    private static string StatusClass(string s) => "status-" + s.ToLower().Replace(" ", "");
}
