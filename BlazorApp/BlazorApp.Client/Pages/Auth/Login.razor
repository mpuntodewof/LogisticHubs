@page "/login"
@layout AuthLayout

@inject AuthService AuthSvc
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Sign In — NiagaOne</PageTitle>

<div class="auth-card">
    <div class="auth-logo">
        <div class="auth-logo-icon">&#128666;</div>
        <div>
            <div class="auth-logo-text">NiagaOne</div>
            <div class="auth-logo-sub">Fleet Management Platform</div>
        </div>
    </div>

    <h1 class="auth-title">Welcome back</h1>
    <p class="auth-subtitle">Sign in to your account to continue</p>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert-custom alert-error">
            &#9888; @_error
        </div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label class="form-label">Email address</label>
            <InputText class="form-control-custom" @bind-Value="_model.Email" placeholder="you@company.com" type="email" autocomplete="email" />
        </div>

        <div class="form-group">
            <label class="form-label">Password</label>
            <InputText class="form-control-custom" @bind-Value="_model.Password" placeholder="••••••••" type="password" autocomplete="current-password" />
        </div>

        <button type="submit" class="btn-primary-custom btn-full" disabled="@_loading">
            @if (_loading) { <span class="spinner" style="border-top-color:#fff"></span> }
            @(_loading ? "Signing in..." : "Sign in")
        </button>
    </EditForm>

    <div class="divider">or</div>

    <p style="text-align:center; font-size:.875rem; color:var(--text-muted)">
        Don't have an account?
        <a href="/register" style="font-weight:600">Create one</a>
    </p>
</div>

@code {
    private readonly LoginRequest _model = new();
    private bool _loading;
    private string _error = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Check actual JWT validity, not just cached user_info existence
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
        {
            Nav.NavigateTo("/dashboard");
        }
    }

    private async Task HandleLogin()
    {
        _loading = true;
        _error = string.Empty;

        var success = await AuthSvc.LoginAsync(_model);
        if (success)
        {
            Nav.NavigateTo("/dashboard");
            return;
        }
        else
            _error = "Invalid email or password. Please try again.";

        _loading = false;
    }
}
