@page "/audit-logs"
@layout AppLayout

@inject ApiClient Api
@inject AuthService AuthSvc

<PageTitle>Audit Logs — NiagaOne</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Audit Logs</h1>
        <div class="page-sub">View system audit trail and activity history</div>
    </div>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading audit logs...</div>
}
else
{
    <div class="card">
        <div style="padding:.75rem 1rem;display:flex;gap:.75rem;flex-wrap:wrap;align-items:center">
            <input class="form-control-custom" placeholder="Search audit logs..." @bind="_search" @bind:event="oninput" @onkeydown="HandleSearchKey" style="max-width:250px" />
            <div class="form-group" style="margin:0">
                <input class="form-control-custom" type="date" @bind="_dateFrom" style="min-width:140px" />
            </div>
            <div class="form-group" style="margin:0">
                <input class="form-control-custom" type="date" @bind="_dateTo" style="min-width:140px" />
            </div>
            <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" @onclick="SearchAsync">Search</button>
        </div>
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>User Email</th>
                        <th>Action</th>
                        <th>Entity Type</th>
                        <th>Entity ID</th>
                        <th>Timestamp</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_pagedResult == null || !_pagedResult.Items.Any())
                    {
                        <tr><td colspan="5">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#128221;</div>
                                <div class="empty-state-text">No audit logs found.</div>
                            </div>
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var log in _pagedResult.Items)
                        {
                            <tr>
                                <td><strong>@(log.UserEmail ?? "—")</strong></td>
                                <td>@log.Action</td>
                                <td>@log.EntityType</td>
                                <td style="color:#64748b;font-size:.85rem">@(log.EntityId ?? "—")</td>
                                <td>@log.Timestamp.ToString("MMM d, yyyy HH:mm:ss")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (_pagedResult != null && _pagedResult.TotalPages > 1)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;border-top:1px solid var(--border)">
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasPreviousPage)" @onclick="PrevPage">Previous</button>
                <span style="font-size:.85rem;color:var(--text-muted)">Page @_pagedResult.Page of @_pagedResult.TotalPages</span>
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasNextPage)" @onclick="NextPage">Next</button>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private string _search = string.Empty;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private int _page = 1;
    private int _pageSize = 20;
    private PagedResult<AuditLogDto>? _pagedResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        _loading = false;
    }

    private async Task LoadDataAsync()
    {
        var apiResult = await Api.GetAuditLogsAsync(_page, _pageSize, _search); if (apiResult.Success) _pagedResult = apiResult.Data;
    }

    private async Task SearchAsync() { _page = 1; await LoadDataAsync(); }
    private async Task HandleSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") await SearchAsync(); }
    private async Task PrevPage() { _page--; await LoadDataAsync(); }
    private async Task NextPage() { _page++; await LoadDataAsync(); }
}
