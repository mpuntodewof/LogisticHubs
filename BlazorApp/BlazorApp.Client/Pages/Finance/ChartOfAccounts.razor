@page "/chart-of-accounts"
@layout AppLayout

@inject ApiClient Api
@inject NavigationManager Nav
@inject AuthService AuthSvc

<PageTitle>Chart of Accounts — StockLedger</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Chart of Accounts</h1>
        <div class="page-sub">Manage your financial account structure</div>
    </div>
    <button class="btn-primary-custom" @onclick="OpenCreate">
        &#43; New Account
    </button>
</div>

@* ── Search ── *@
<div class="card" style="margin-bottom:1rem;padding:1rem">
    <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center">
        <div class="form-group" style="margin:0;flex:1;min-width:200px">
            <input class="form-control-custom" placeholder="Search by code or name..." @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
        </div>
    </div>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading accounts...</div>
}
else
{
    <div class="card">
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Account Code</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Normal Balance</th>
                        <th>Active</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (_items == null || !_items.Any())
                    {
                        <tr><td colspan="6">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#128209;</div>
                                <div class="empty-state-text">No accounts found.</div>
                            </div>
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var a in _items)
                        {
                            <tr>
                                <td><strong>@a.AccountCode</strong></td>
                                <td>@a.Name</td>
                                <td>@a.AccountType</td>
                                <td>@a.NormalBalance</td>
                                <td>
                                    <span class="badge-status @(a.IsActive ? "status-active" : "status-inactive")">
                                        @(a.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <button class="btn-outline" style="padding:.3rem .7rem;font-size:.75rem" @onclick="@(() => OpenEdit(a))">Edit</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* ── Pagination ── *@
        @if (_totalPages > 1)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:1rem;border-top:1px solid #e2e8f0">
                <span style="font-size:.85rem;color:#64748b">Page @_page of @_totalPages (@_totalCount total)</span>
                <div style="display:flex;gap:.5rem">
                    <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" disabled="@(!_hasPrevious)" @onclick="PreviousPage">Previous</button>
                    <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" disabled="@(!_hasNext)" @onclick="NextPage">Next</button>
                </div>
            </div>
        }
    </div>
}

@* ── Edit Modal ── *@
@if (_showEdit)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;display:flex;align-items:center;justify-content:center">
        <div class="card" style="width:460px;max-width:95vw">
            <div class="card-header-custom">
                <span class="card-title-custom">Edit Account</span>
                <button class="btn-logout" @onclick="() => _showEdit = false">&#x2715;</button>
            </div>
            <div class="card-body-custom">
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="alert-custom alert-error">&#9888; @_formError</div>
                }
                <div class="form-group">
                    <label class="form-label">Account Code</label>
                    <input class="form-control-custom" value="@_editCode" disabled />
                </div>
                <div class="form-group">
                    <label class="form-label">Account Type</label>
                    <input class="form-control-custom" value="@_editType" disabled />
                </div>
                <div class="form-group">
                    <label class="form-label">Name</label>
                    <input class="form-control-custom" @bind="_editReq.Name" />
                </div>
                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select class="form-control-custom" @bind="_editActive">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>
                <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem">
                    <button class="btn-outline" @onclick="() => _showEdit = false">Cancel</button>
                    <button class="btn-primary-custom" @onclick="UpdateAsync" disabled="@_saving">
                        @if (_saving) { <span class="spinner" style="border-top-color:#fff"></span> }
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Create Modal ── *@
@if (_showCreate)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;display:flex;align-items:center;justify-content:center">
        <div class="card" style="width:460px;max-width:95vw">
            <div class="card-header-custom">
                <span class="card-title-custom">New Account</span>
                <button class="btn-logout" @onclick="() => _showCreate = false">&#x2715;</button>
            </div>
            <div class="card-body-custom">
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="alert-custom alert-error">&#9888; @_formError</div>
                }
                <div class="form-group">
                    <label class="form-label">Account Code</label>
                    <input class="form-control-custom" @bind="_createReq.AccountCode" placeholder="1000" />
                </div>
                <div class="form-group">
                    <label class="form-label">Name</label>
                    <input class="form-control-custom" @bind="_createReq.Name" placeholder="Cash and Cash Equivalents" />
                </div>
                <div class="form-group">
                    <label class="form-label">Account Type</label>
                    <select class="form-control-custom" @bind="_createReq.AccountType">
                        <option value="">-- Select Type --</option>
                        <option value="Asset">Asset</option>
                        <option value="Liability">Liability</option>
                        <option value="Equity">Equity</option>
                        <option value="Revenue">Revenue</option>
                        <option value="Expense">Expense</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Normal Balance</label>
                    <select class="form-control-custom" @bind="_normalBalance">
                        <option value="">-- Select --</option>
                        <option value="Debit">Debit</option>
                        <option value="Credit">Credit</option>
                    </select>
                </div>
                <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem">
                    <button class="btn-outline" @onclick="() => _showCreate = false">Cancel</button>
                    <button class="btn-primary-custom" @onclick="CreateAsync" disabled="@_saving">
                        @if (_saving) { <span class="spinner" style="border-top-color:#fff"></span> }
                        Create
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _showCreate;
    private bool _showEdit;
    private bool _saving;
    private string _formError = string.Empty;
    private string _search = string.Empty;
    private string _normalBalance = string.Empty;

    private List<ChartOfAccountDto> _items = new();
    private CreateChartOfAccountRequest _createReq = new();
    private UpdateChartOfAccountRequest _editReq = new();
    private Guid _editId;
    private string _editCode = string.Empty;
    private string _editType = string.Empty;
    private bool _editActive = true;

    private int _page = 1;
    private int _pageSize = 20;
    private int _totalCount;
    private int _totalPages;
    private bool _hasPrevious;
    private bool _hasNext;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var result = await Api.GetChartOfAccountsAsync(_page, _pageSize, string.IsNullOrWhiteSpace(_search) ? null : _search.Trim());
            if (result.Success && result.Data != null)
            {
                _items = result.Data.Items;
                _totalCount = result.Data.TotalCount;
                _totalPages = result.Data.TotalPages;
                _hasPrevious = result.Data.HasPreviousPage;
                _hasNext = result.Data.HasNextPage;
            }
        }
        catch { }
        _loading = false;
    }

    private async Task OnSearchKeyUp(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task PreviousPage() { if (_hasPrevious) { _page--; await LoadAsync(); } }
    private async Task NextPage() { if (_hasNext) { _page++; await LoadAsync(); } }

    private void OpenCreate()
    {
        _createReq = new();
        _normalBalance = string.Empty;
        _formError = string.Empty;
        _showCreate = true;
    }

    private void OpenEdit(ChartOfAccountDto item)
    {
        _editId = item.Id;
        _editCode = item.AccountCode;
        _editType = item.AccountType;
        _editActive = item.IsActive;
        _editReq = new UpdateChartOfAccountRequest
        {
            Name = item.Name,
            IsActive = item.IsActive
        };
        _formError = string.Empty;
        _showEdit = true;
    }

    private async Task UpdateAsync()
    {
        _saving = true;
        _formError = string.Empty;
        _editReq.IsActive = _editActive;

        var result = await Api.UpdateChartOfAccountAsync(_editId, _editReq);
        if (result.Success)
        {
            _showEdit = false;
            await LoadAsync();
        }
        else
        {
            _formError = result.ErrorMessage ?? "Failed to update account.";
        }

        _saving = false;
    }

    private async Task CreateAsync()
    {
        _saving = true;
        _formError = string.Empty;

        var result = await Api.CreateChartOfAccountAsync(_createReq);
        if (result.Success && result.Data != null)
        {
            _showCreate = false;
            _page = 1;
            await LoadAsync();
        }
        else
        {
            _formError = result.ErrorMessage ?? "Failed to create account.";
        }

        _saving = false;
    }
}
