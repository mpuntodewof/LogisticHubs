@page "/branches"
@layout AppLayout

@inject ApiClient Api
@inject NavigationManager Nav
@inject AuthService AuthSvc

<PageTitle>Branches — NiagaOne</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Branches</h1>
        <div class="page-sub">Manage branch office locations</div>
    </div>
    <button class="btn-primary-custom" @onclick="OpenCreate">
        &#43; New Branch
    </button>
</div>

@* ── Search ── *@
<div class="card" style="margin-bottom:1rem;padding:1rem">
    <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center">
        <div class="form-group" style="margin:0;flex:1;min-width:200px">
            <input class="form-control-custom" placeholder="Search by name, code, or city..." @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
        </div>
    </div>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading branches...</div>
}
else
{
    <div class="card">
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Code</th>
                        <th>City</th>
                        <th>Province</th>
                        <th>Warehouse</th>
                        <th>Active</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (_items == null || !_items.Any())
                    {
                        <tr><td colspan="7">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#127970;</div>
                                <div class="empty-state-text">No branches configured yet.</div>
                            </div>
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var b in _items)
                        {
                            <tr>
                                <td><strong>@b.Name</strong></td>
                                <td>@b.Code</td>
                                <td>@(b.City ?? "-")</td>
                                <td>@(b.Province ?? "-")</td>
                                <td>@(b.WarehouseName ?? "-")</td>
                                <td>
                                    <span class="badge-status @(b.IsActive ? "status-active" : "status-inactive")">
                                        @(b.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <button class="btn-outline" style="padding:.3rem .7rem;font-size:.75rem" @onclick="@(() => {})">Edit</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* ── Pagination ── *@
        @if (_totalPages > 1)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:1rem;border-top:1px solid #e2e8f0">
                <span style="font-size:.85rem;color:#64748b">Page @_page of @_totalPages (@_totalCount total)</span>
                <div style="display:flex;gap:.5rem">
                    <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" disabled="@(!_hasPrevious)" @onclick="PreviousPage">Previous</button>
                    <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" disabled="@(!_hasNext)" @onclick="NextPage">Next</button>
                </div>
            </div>
        }
    </div>
}

@* ── Create Modal ── *@
@if (_showCreate)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;display:flex;align-items:center;justify-content:center">
        <div class="card" style="width:460px;max-width:95vw">
            <div class="card-header-custom">
                <span class="card-title-custom">New Branch</span>
                <button class="btn-logout" @onclick="() => _showCreate = false">&#x2715;</button>
            </div>
            <div class="card-body-custom">
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="alert-custom alert-error">&#9888; @_formError</div>
                }
                <div class="form-group">
                    <label class="form-label">Name</label>
                    <input class="form-control-custom" @bind="_createReq.Name" placeholder="Jakarta Pusat Branch" />
                </div>
                <div class="form-group">
                    <label class="form-label">Code</label>
                    <input class="form-control-custom" @bind="_createReq.Code" placeholder="BR-JKT-01" />
                </div>
                <div class="form-group">
                    <label class="form-label">Address</label>
                    <input class="form-control-custom" @bind="_address" placeholder="Jl. Sudirman No. 1" />
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">
                    <div class="form-group">
                        <label class="form-label">City</label>
                        <input class="form-control-custom" @bind="_createReq.City" placeholder="Jakarta Pusat" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Province</label>
                        <input class="form-control-custom" @bind="_createReq.Province" placeholder="DKI Jakarta" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Phone</label>
                    <input class="form-control-custom" @bind="_phone" placeholder="+62 21-1234-5678" />
                </div>
                <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem">
                    <button class="btn-outline" @onclick="() => _showCreate = false">Cancel</button>
                    <button class="btn-primary-custom" @onclick="CreateAsync" disabled="@_saving">
                        @if (_saving) { <span class="spinner" style="border-top-color:#fff"></span> }
                        Create
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _showCreate;
    private bool _saving;
    private string _formError = string.Empty;
    private string _search = string.Empty;
    private string _address = string.Empty;
    private string _phone = string.Empty;

    private List<BranchDto> _items = new();
    private CreateBranchRequest _createReq = new();

    private int _page = 1;
    private int _pageSize = 20;
    private int _totalCount;
    private int _totalPages;
    private bool _hasPrevious;
    private bool _hasNext;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var result = await Api.GetBranchesAsync(_page, _pageSize, string.IsNullOrWhiteSpace(_search) ? null : _search.Trim());
            if (result != null)
            {
                _items = result.Items;
                _totalCount = result.TotalCount;
                _totalPages = result.TotalPages;
                _hasPrevious = result.HasPreviousPage;
                _hasNext = result.HasNextPage;
            }
        }
        catch { }
        _loading = false;
    }

    private async Task OnSearchKeyUp(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task PreviousPage() { if (_hasPrevious) { _page--; await LoadAsync(); } }
    private async Task NextPage() { if (_hasNext) { _page++; await LoadAsync(); } }

    private void OpenCreate()
    {
        _createReq = new();
        _address = string.Empty;
        _phone = string.Empty;
        _formError = string.Empty;
        _showCreate = true;
    }

    private async Task CreateAsync()
    {
        _saving = true;
        _formError = string.Empty;

        var result = await Api.CreateBranchAsync(_createReq);
        if (result != null)
        {
            _showCreate = false;
            _page = 1;
            await LoadAsync();
        }
        else
        {
            _formError = "Failed to create branch.";
        }

        _saving = false;
    }
}
