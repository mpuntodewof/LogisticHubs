@page "/storefront-config"
@layout AppLayout

@inject ApiClient Api
@inject AuthService AuthSvc

<PageTitle>Storefront Config — NiagaOne</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Storefront Configuration</h1>
        <div class="page-sub">Manage your storefront settings and appearance</div>
    </div>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading storefront config...</div>
}
else if (_config == null)
{
    <div class="card">
        <div class="card-body-custom">
            <div class="empty-state">
                <div class="empty-state-icon">&#127760;</div>
                <div class="empty-state-text">Config not set up yet. Please configure your storefront settings via the API.</div>
            </div>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-header-custom">
            <span class="card-title-custom">Current Configuration</span>
        </div>
        <div class="card-body-custom">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
                <div class="form-group">
                    <label class="form-label">Config Key</label>
                    <input class="form-control-custom" value="@_config.Key" readonly />
                </div>
                <div class="form-group">
                    <label class="form-label">Value</label>
                    <input class="form-control-custom" value="@(_config.Value ?? "—")" readonly />
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private StorefrontConfigDto? _config;

    protected override async Task OnInitializedAsync()
    {
        try { _config = await Api.GetStorefrontConfigAsync(); } catch { }
        _loading = false;
    }
}
