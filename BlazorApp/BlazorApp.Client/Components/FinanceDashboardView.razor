@inject BlazorApp.Client.Services.ApiClient Api
@inject NavigationManager Nav

@* Reusable Finance Dashboard body — rendered inside /dashboard for Accountants. *@

<div class="page-header">
    <div>
        <h1>Finance Dashboard</h1>
        <p class="page-desc">Receivables, month-to-date P&amp;L, and channel performance</p>
    </div>
    @if (_data != null)
    {
        <div style="display:flex;align-items:center;gap:.5rem">
            <span class="pulse-dot"></span>
            <span style="font-size:.7rem;color:var(--text-muted);font-weight:500">LIVE</span>
        </div>
    }
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading finance dashboard...</div>
}
else if (!string.IsNullOrEmpty(_error))
{
    <div class="alert-custom alert-error" style="margin-bottom:1rem">
        &#9888; @_error
    </div>
}
else if (_data != null)
{
    @* ── Top row: Finance KPIs ───────────────────────────────────────── *@
    <div class="dash-section-title">This Month at a Glance</div>
    <div class="dash-grid-4 mb-lg">
        <div class="glow-card glow-emerald anim-enter anim-d1">
            <span class="glow-stat-icon">&#128181;</span>
            <div class="glow-stat-label">Revenue (MTD)</div>
            <div class="glow-stat-value">Rp @_data.Finance.MonthlyRevenue.ToString("N0")</div>
            <div class="glow-stat-trend trend-up">From posted entries</div>
        </div>
        <div class="glow-card glow-rose anim-enter anim-d2">
            <span class="glow-stat-icon">&#128176;</span>
            <div class="glow-stat-label">Expenses (MTD)</div>
            <div class="glow-stat-value">Rp @_data.Finance.MonthlyExpenses.ToString("N0")</div>
            <div class="glow-stat-trend">@ExpensePct() of revenue</div>
        </div>
        <div class="glow-card glow-indigo anim-enter anim-d3">
            <span class="glow-stat-icon">&#128196;</span>
            <div class="glow-stat-label">Outstanding Invoices</div>
            <div class="glow-stat-value">@_data.Finance.OutstandingInvoices</div>
            <div class="glow-stat-trend">AR: Rp @_data.Finance.TotalReceivables.ToString("N0")</div>
        </div>
        <div class="glow-card glow-amber anim-enter anim-d4">
            <span class="glow-stat-icon">&#9888;</span>
            <div class="glow-stat-label">Overdue</div>
            <div class="glow-stat-value" style="@(_data.Finance.OverdueInvoices > 0 ? "color:#FB7185" : "")">@_data.Finance.OverdueInvoices</div>
            @if (_data.Finance.OverdueInvoices > 0)
            {
                <div class="glow-stat-trend trend-down">Rp @_data.Finance.OverdueAmount.ToString("N0")</div>
            }
            else
            {
                <div class="glow-stat-trend trend-up">All current</div>
            }
        </div>
    </div>

    @* ── P&L summary + Channel breakdown ────────────────────────────── *@
    <div class="dash-grid-2 mb-lg">
        <div class="glow-card glow-emerald anim-enter anim-d5">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem">
                <h3 style="font-size:.9rem;font-weight:700;margin:0;color:var(--text-primary)">Profit &amp; Loss (MTD)</h3>
                <a href="/reports" style="font-size:.7rem;color:var(--accent);text-decoration:none;font-weight:600">Full report &rarr;</a>
            </div>
            <div class="dash-grid-2" style="gap:.75rem;margin-bottom:1rem">
                <div>
                    <div class="pnl-label">Revenue</div>
                    <div class="pnl-value" style="color:#34D399">Rp @_data.MonthToDateProfitAndLoss.TotalRevenue.ToString("N0")</div>
                </div>
                <div>
                    <div class="pnl-label">COGS</div>
                    <div class="pnl-value">Rp @_data.MonthToDateProfitAndLoss.TotalCogs.ToString("N0")</div>
                </div>
                <div>
                    <div class="pnl-label">Gross Profit</div>
                    <div class="pnl-value" style="color:#818CF8">Rp @_data.MonthToDateProfitAndLoss.GrossProfit.ToString("N0")</div>
                    <div style="font-size:.7rem;color:var(--text-muted);margin-top:.15rem">@_data.MonthToDateProfitAndLoss.GrossProfitMargin.ToString("F1")% margin</div>
                </div>
                <div>
                    <div class="pnl-label">Net Profit</div>
                    <div class="pnl-value" style="color:@(_data.MonthToDateProfitAndLoss.NetProfit >= 0 ? "#22D3EE" : "#FB7185")">Rp @_data.MonthToDateProfitAndLoss.NetProfit.ToString("N0")</div>
                    <div style="font-size:.7rem;color:var(--text-muted);margin-top:.15rem">@_data.MonthToDateProfitAndLoss.NetProfitMargin.ToString("F1")% margin</div>
                </div>
            </div>
        </div>

        <div class="glow-card glow-cyan anim-enter anim-d6">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
                <h3 style="font-size:.9rem;font-weight:700;margin:0;color:var(--text-primary)">Channel Performance</h3>
                <span style="font-size:.6rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em">Net after fees</span>
            </div>
            @if (_data.ChannelBreakdown.Count == 0)
            {
                <div class="empty-state" style="padding:2rem 1rem"><div class="empty-state-text">No channel data yet</div></div>
            }
            else
            {
                var topChannels = _data.ChannelBreakdown
                    .OrderByDescending(c => c.Revenue)
                    .Take(ChannelPreviewLimit)
                    .ToList();
                var maxRev = topChannels.Max(c => c.Revenue);
                foreach (var c in topChannels)
                {
                    var pct = maxRev > 0 ? ((double)c.Revenue / (double)maxRev * 100.0).ToString("F0") : "0";
                    <div class="channel-row">
                        <div class="channel-name">
                            <div style="font-weight:600;font-size:.8rem;color:var(--text-primary)">@c.ChannelName</div>
                            <div style="font-size:.65rem;color:var(--text-muted)">Fees: Rp @c.PlatformFees.ToString("N0")</div>
                        </div>
                        <div class="channel-bar-wrap">
                            <div class="progress-track">
                                <div class="progress-fill fill-indigo" style="@($"width:{pct}%")"></div>
                            </div>
                        </div>
                        <div class="channel-value" style="color:#22D3EE">Rp @c.NetRevenue.ToString("N0")</div>
                    </div>
                }
                @if (_data.ChannelBreakdown.Count > ChannelPreviewLimit)
                {
                    <div style="text-align:center;margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--border)">
                        <button class="btn-outline" style="padding:.4rem 1rem;font-size:.75rem" @onclick="OpenChannelsDialog">
                            Show all @_data.ChannelBreakdown.Count channels &rarr;
                        </button>
                    </div>
                }
            }
        </div>
    </div>

    @* ── Recent Invoices ─────────────────────────────────────────────── *@
    <div class="glow-card glow-violet anim-enter anim-d7">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
            <h3 style="font-size:.9rem;font-weight:700;margin:0;color:var(--text-primary)">Recent Invoices</h3>
            <a href="/invoices" style="font-size:.7rem;color:var(--accent);text-decoration:none;font-weight:600">View all &rarr;</a>
        </div>
        @if (_data.RecentInvoices.Count == 0)
        {
            <div class="empty-state" style="padding:2rem 1rem"><div class="empty-state-text">No invoices yet</div></div>
        }
        else
        {
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Invoice #</th>
                        <th>Counterparty</th>
                        <th>Status</th>
                        <th style="text-align:right">Amount</th>
                        <th>Invoice Date</th>
                        <th>Due</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in _data.RecentInvoices)
                    {
                        <tr>
                            <td style="font-weight:600;color:var(--text-primary)">@inv.InvoiceNumber</td>
                            <td>@(inv.CounterpartyName ?? "—")</td>
                            <td><span class="badge-status @StatusBadge(inv.Status)">@inv.Status</span></td>
                            <td style="text-align:right;font-weight:600">Rp @inv.GrandTotal.ToString("N0")</td>
                            <td style="color:var(--text-muted)">@inv.InvoiceDate.ToString("yyyy-MM-dd")</td>
                            <td style="color:@(DueColor(inv.DueDate, inv.Status))">@inv.DueDate.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* ── All Channels dialog ────────────────────────────────────────── *@
    @if (_showChannelsDialog && _data != null)
    {
        <div class="modal-backdrop" @onclick="CloseChannelsDialog">
            <div class="modal-card" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3 style="margin:0;font-size:1rem;font-weight:700">All Channels (@_data.ChannelBreakdown.Count)</h3>
                    <button class="modal-close" @onclick="CloseChannelsDialog" aria-label="Close">&times;</button>
                </div>
                <div class="modal-body">
                    <table class="lh-table">
                        <thead>
                            <tr>
                                <th>Channel</th>
                                <th style="text-align:right">Revenue</th>
                                <th style="text-align:right">Platform Fees</th>
                                <th style="text-align:right">Net Revenue</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in _data.ChannelBreakdown.OrderByDescending(c => c.Revenue))
                            {
                                <tr>
                                    <td style="font-weight:600;color:var(--text-primary)">@c.ChannelName</td>
                                    <td style="text-align:right">Rp @c.Revenue.ToString("N0")</td>
                                    <td style="text-align:right;color:#FB7185">Rp @c.PlatformFees.ToString("N0")</td>
                                    <td style="text-align:right;font-weight:600;color:#22D3EE">Rp @c.NetRevenue.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@code {
    private const int ChannelPreviewLimit = 5;

    private bool _loading = true;
    private string _error = string.Empty;
    private bool _showChannelsDialog;
    private BlazorApp.Client.Models.FinanceDashboardSummary? _data;

    protected override async Task OnInitializedAsync()
    {
        var result = await Api.GetFinanceDashboardSummaryAsync();
        if (result.Success && result.Data != null)
        {
            _data = result.Data;
        }
        else if (result.IsUnauthorized)
        {
            Nav.NavigateTo("/login");
            return;
        }
        else if (result.IsForbidden)
        {
            _error = "You don't have permission to view the Finance Dashboard.";
        }
        else
        {
            _error = result.ErrorMessage ?? "Failed to load finance dashboard.";
        }
        _loading = false;
    }

    private void OpenChannelsDialog() => _showChannelsDialog = true;
    private void CloseChannelsDialog() => _showChannelsDialog = false;

    private string ExpensePct()
    {
        if (_data == null || _data.Finance.MonthlyRevenue <= 0) return "—";
        var pct = (double)_data.Finance.MonthlyExpenses / (double)_data.Finance.MonthlyRevenue * 100.0;
        return $"{pct:F0}%";
    }

    private static string StatusBadge(string status) => status switch
    {
        "Paid" => "badge-success",
        "Issued" => "badge-info",
        "Overdue" => "badge-warning",
        "Cancelled" => "badge-muted",
        _ => "badge-muted"
    };

    private static string DueColor(DateTime due, string status)
    {
        if (status == "Paid" || status == "Cancelled") return "var(--text-muted)";
        return due < DateTime.UtcNow.Date ? "#FB7185" : "var(--text-muted)";
    }
}

<style>
    .pnl-label {
        font-size: .65rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: .25rem;
    }
    .pnl-value {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--text-primary);
    }

    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.55);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        animation: fade-in .15s ease-out;
    }
    .modal-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 14px;
        width: min(700px, calc(100vw - 2rem));
        max-height: calc(100vh - 4rem);
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.35);
    }
    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--border);
    }
    .modal-close {
        background: transparent;
        border: none;
        color: var(--text-muted);
        font-size: 1.4rem;
        line-height: 1;
        cursor: pointer;
        padding: .25rem .5rem;
        border-radius: 4px;
    }
    .modal-close:hover { background: rgba(148, 163, 184, 0.1); color: var(--text-primary); }
    .modal-body {
        padding: 1rem 1.25rem;
        overflow-y: auto;
    }
    @@keyframes fade-in {
        from { opacity: 0; }
        to { opacity: 1; }
    }
</style>
