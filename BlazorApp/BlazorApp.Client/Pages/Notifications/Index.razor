@page "/notifications"
@layout AppLayout

@inject ApiClient Api
@inject AuthService AuthSvc

<PageTitle>Notifications — NiagaOne</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Notifications</h1>
        <div class="page-sub">View your notifications and alerts</div>
    </div>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading notifications...</div>
}
else
{
    <div class="card">
        <div style="padding:.75rem 1rem;display:flex;gap:.75rem;align-items:center">
            <input class="form-control-custom" placeholder="Search notifications..." @bind="_search" @bind:event="oninput" @onkeydown="HandleSearchKey" style="max-width:300px" />
            <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" @onclick="SearchAsync">Search</button>
        </div>
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Message</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (_pagedResult == null || !_pagedResult.Items.Any())
                    {
                        <tr><td colspan="5">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#128276;</div>
                                <div class="empty-state-text">No notifications found.</div>
                            </div>
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var n in _pagedResult.Items)
                        {
                            <tr>
                                <td><strong>@n.Title</strong></td>
                                <td style="color:#64748b">@Truncate(n.Message, 100)</td>
                                <td><span class="badge-status @StatusClass(n.Status)">@n.Status</span></td>
                                <td>@n.CreatedAt.ToString("MMM d, yyyy HH:mm")</td>
                                <td>
                                    @if (n.Status.Equals("Unread", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <button class="btn-outline" style="padding:.3rem .7rem;font-size:.75rem" @onclick="() => MarkReadAsync(n)" disabled="@_marking">
                                            Mark Read
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (_pagedResult != null && _pagedResult.TotalPages > 1)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;border-top:1px solid var(--border)">
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasPreviousPage)" @onclick="PrevPage">Previous</button>
                <span style="font-size:.85rem;color:var(--text-muted)">Page @_pagedResult.Page of @_pagedResult.TotalPages</span>
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasNextPage)" @onclick="NextPage">Next</button>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private bool _marking;
    private string _search = string.Empty;
    private int _page = 1;
    private int _pageSize = 20;
    private PagedResult<NotificationDto>? _pagedResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        _loading = false;
    }

    private async Task LoadDataAsync()
    {
        try { _pagedResult = await Api.GetMyNotificationsAsync(_page, _pageSize, _search); } catch { }
    }

    private async Task SearchAsync() { _page = 1; await LoadDataAsync(); }
    private async Task HandleSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") await SearchAsync(); }
    private async Task PrevPage() { _page--; await LoadDataAsync(); }
    private async Task NextPage() { _page++; await LoadDataAsync(); }

    private async Task MarkReadAsync(NotificationDto n)
    {
        _marking = true;
        var ok = await Api.MarkNotificationReadAsync(n.Id);
        if (ok) await LoadDataAsync();
        _marking = false;
    }

    private static string Truncate(string? text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return "—";
        return text.Length <= maxLength ? text : text[..maxLength] + "...";
    }

    private static string StatusClass(string s) => "status-" + s.ToLower().Replace(" ", "");
}
