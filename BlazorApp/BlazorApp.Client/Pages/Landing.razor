<!-- ═══ FEATURES ═══ -->
<section class="features-section" id="features">
    <div class="landing-container">
        <div class="section-label">Core Features</div>
        <h2 class="section-title">Everything you need. Nothing you don't.</h2>
        <p class="section-subtitle">StockLedger focuses on two things and does them exceptionally well: inventory and finances.</p>

        <div class="features-grid">
            <div class="feature-card feature-primary">
                <div class="feature-icon-wrap blue">&#128230;</div>
                <h3>Multi-Channel Stock Sync</h3>
                <p>Import sales from any marketplace or offline channel via CSV. One dashboard shows real stock across all warehouses.</p>
                <ul class="feature-list">
                    <li>CSV import from marketplace exports</li>
                    <li>Auto stock deduction on import</li>
                    <li>Multi-warehouse tracking</li>
                    <li>Immutable movement audit trail</li>
                </ul>
            </div>
            <div class="feature-card feature-primary">
                <div class="feature-icon-wrap green">&#128200;</div>
                <h3>Real Profitability Data</h3>
                <p>See true margin per product and per channel — after platform fees, shipping, and COGS. Know where your money goes.</p>
                <ul class="feature-list">
                    <li>P&L by channel (per marketplace & offline)</li>
                    <li>Margin per SKU</li>
                    <li>Platform fee tracking</li>
                    <li>Double-entry accounting</li>
                </ul>
            </div>
            <div class="feature-card">
                <div class="feature-icon-wrap amber">&#128196;</div>
                <h3>Tax Compliance</h3>
                <p>PPN 11% auto-tracked on every transaction. e-Faktur numbering built in. Month-end tax prep in hours, not days.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon-wrap cyan">&#128666;</div>
                <h3>Full Purchasing Cycle</h3>
                <p>Create POs, track approvals, receive goods — stock updates automatically. Complete supplier management.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon-wrap purple">&#128272;</div>
                <h3>Team Permissions</h3>
                <p>70+ granular permissions. Give warehouse staff inventory access, accountants finance access. Full RBAC.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon-wrap slate">&#128270;</div>
                <h3>Complete Audit Trail</h3>
                <p>Every stock movement, every journal entry, every login — logged and immutable. Full compliance ready.</p>
            </div>
        </div>
    </div>
</section>

<!-- ═══ HOW IT WORKS ═══ -->
<section class="how-section" id="how-it-works">
