@inherits LayoutComponentBase
@inject AuthService AuthSvc
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

@if (!_authChecked)
{
    <div style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#0F172A">
        <div class="loading-spinner"><div class="spinner"></div> Loading...</div>
    </div>
}
else
{
    <div class="app-wrapper">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <div class="brand-icon">&#128230;</div>
                <div>
                    <div class="brand-name">StockLedger</div>
                    <div class="brand-sub">Inventory + Finance</div>
                </div>
            </div>

            <div class="sidebar-section">Main</div>
            <NavLink class="nav-item-link" href="/dashboard" Match="NavLinkMatch.All">
                <span class="nav-icon">&#128202;</span> Dashboard
            </NavLink>

            @if (Has("products.read") || Has("categories.read") || Has("brands.read") || Has("units.read"))
            {
                <div class="sidebar-section">Catalog</div>
                @if (Has("products.read"))
                {
                    <NavLink class="nav-item-link" href="/products">
                        <span class="nav-icon">&#128722;</span> Products
                    </NavLink>
                }
                @if (Has("categories.read"))
                {
                    <NavLink class="nav-item-link" href="/categories">
                        <span class="nav-icon">&#128193;</span> Categories
                    </NavLink>
                }
                @if (Has("brands.read"))
                {
                    <NavLink class="nav-item-link" href="/brands">
                        <span class="nav-icon">&#127991;</span> Brands
                    </NavLink>
                }
                @if (Has("units.read"))
                {
                    <NavLink class="nav-item-link" href="/units-of-measure">
                        <span class="nav-icon">&#128207;</span> Units
                    </NavLink>
                }
            }

            @if (Has("inventory.read") || Has("warehouses.manage"))
            {
                <div class="sidebar-section">Inventory</div>
                @if (Has("warehouses.manage"))
                {
                    <NavLink class="nav-item-link" href="/warehouses">
                        <span class="nav-icon">&#127970;</span> Warehouses
                    </NavLink>
                }
                @if (Has("inventory.read"))
                {
                    <NavLink class="nav-item-link" href="/warehouse-stock">
                        <span class="nav-icon">&#128230;</span> Stock Levels
                    </NavLink>
                    <NavLink class="nav-item-link" href="/stock-movements">
                        <span class="nav-icon">&#128260;</span> Movements
                    </NavLink>
                }
                @if (Has("inventory.create"))
                {
                    <NavLink class="nav-item-link" href="/import" Match="NavLinkMatch.All">
                        <span class="nav-icon">&#128229;</span><span class="sidebar-text">Import Sales</span>
                    </NavLink>
                }
            }

            @if (Has("chart-of-accounts.read") || Has("invoices.read"))
            {
                <div class="sidebar-section">Finance</div>
                @if (Has("chart-of-accounts.read"))
                {
                    <NavLink class="nav-item-link" href="/chart-of-accounts">
                        <span class="nav-icon">&#128209;</span> Chart of Accounts
                    </NavLink>
                }
                @if (Has("journal-entries.read"))
                {
                    <NavLink class="nav-item-link" href="/journal-entries">
                        <span class="nav-icon">&#128221;</span> Journal Entries
                    </NavLink>
                }
                @if (Has("invoices.read"))
                {
                    <NavLink class="nav-item-link" href="/invoices">
                        <span class="nav-icon">&#128196;</span> Invoices
                    </NavLink>
                }
                @if (Has("tax-rates.read"))
                {
                    <NavLink class="nav-item-link" href="/tax-rates">
                        <span class="nav-icon">&#128181;</span> Tax Rates
                    </NavLink>
                }
                @if (Has("payment-terms.read"))
                {
                    <NavLink class="nav-item-link" href="/payment-terms">
                        <span class="nav-icon">&#128197;</span> Payment Terms
                    </NavLink>
                }
                <NavLink class="nav-item-link" href="/reports" Match="NavLinkMatch.All">
                    <span class="nav-icon">&#128200;</span><span class="sidebar-text">Reports</span>
                </NavLink>
            }

            @if (Has("audit-logs.read"))
            {
                <div class="sidebar-section">Audit</div>
                <NavLink class="nav-item-link" href="/audit-logs">
                    <span class="nav-icon">&#128270;</span> Audit Logs
                </NavLink>
            }

            <div class="sidebar-section">Account</div>
            @if (Has("users.read"))
            {
                <NavLink class="nav-item-link" href="/users">
                    <span class="nav-icon">&#128100;</span> Users
                </NavLink>
            }
            @if (Has("roles.read"))
            {
                <NavLink class="nav-item-link" href="/roles">
                    <span class="nav-icon">&#128272;</span> Roles
                </NavLink>
            }
            @if (Has("tenant-settings.read"))
            {
                <NavLink class="nav-item-link" href="/settings">
                    <span class="nav-icon">&#9881;</span> Settings
                </NavLink>
            }
            <NavLink class="nav-item-link" href="/profile">
                <span class="nav-icon">&#128736;</span> Profile
            </NavLink>

            <div class="sidebar-footer">
                <div class="user-chip">
                    <div class="user-avatar">@_initials</div>
                    <div>
                        <div class="user-name">@_userName</div>
                        <div class="user-role">@_userRole</div>
                    </div>
                    <button class="btn-primary-custom" style="padding:.4rem 1rem;font-size:.75rem;margin-left:auto" @onclick="LogoutAsync">Logout</button>
                </div>
            </div>
        </aside>

        <div class="main-content">
            <div class="page-content">
                @Body
            </div>
        </div>
    </div>
}

@code {
    private bool _authChecked;
    private string _userName = "User";
    private string _userRole = "";
    private string _initials = "U";
    private HashSet<string> _permissions = new();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var isAuth = state.User.Identity?.IsAuthenticated == true;

        if (!isAuth)
        {
            await AuthSvc.LogoutAsync();
            Nav.NavigateTo("/login");
            return;
        }

        var user = await AuthSvc.GetCurrentUserAsync();
        if (user == null)
        {
            await AuthSvc.LogoutAsync();
            Nav.NavigateTo("/login");
            return;
        }

        _userName = user.Name;
        _userRole = user.Roles.FirstOrDefault() ?? "Viewer";
        _initials = string.Concat(user.Name.Split(' ').Select(w => w.FirstOrDefault())).ToUpper();
        if (_initials.Length > 2) _initials = _initials[..2];

        _permissions = state.User.Claims
            .Where(c => c.Type == "permissions")
            .Select(c => c.Value)
            .ToHashSet();

        _authChecked = true;
    }

    private bool Has(string permission) => _permissions.Contains(permission);

    private async Task LogoutAsync()
    {
        await AuthSvc.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}
