@page "/sales-orders"
@layout AppLayout

@inject ApiClient Api
@inject NavigationManager Nav
@inject AuthService AuthSvc

<PageTitle>Sales Orders — NiagaOne</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Sales Orders</h1>
        <div class="page-sub">Manage customer orders</div>
    </div>
    <button class="btn-primary-custom" @onclick="() => _showCreate = true">
        &#43; New Order
    </button>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading sales orders...</div>
}
else
{
    <div class="card">
        <div style="padding:.75rem 1rem;display:flex;gap:.75rem;align-items:center">
            <input class="form-control-custom" placeholder="Search orders..." @bind="_search" @bind:event="oninput" @onkeydown="HandleSearchKey" style="max-width:300px" />
            <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" @onclick="SearchAsync">Search</button>
        </div>
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Type</th>
                        <th>Customer</th>
                        <th>Branch</th>
                        <th>Status</th>
                        <th>Grand Total</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_pagedResult == null || !_pagedResult.Items.Any())
                    {
                        <tr><td colspan="7">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#128196;</div>
                                <div class="empty-state-text">No sales orders found.</div>
                            </div>
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var o in _pagedResult.Items)
                        {
                            <tr>
                                <td><strong>@o.OrderNumber</strong></td>
                                <td>@o.OrderType</td>
                                <td>@o.CustomerName</td>
                                <td>@(o.BranchName ?? "—")</td>
                                <td><span class="badge-status @StatusClass(o.Status)">@o.Status</span></td>
                                <td>@($"Rp {o.GrandTotal:N0}")</td>
                                <td>@o.OrderDate.ToString("MMM d, yyyy")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (_pagedResult != null && _pagedResult.TotalPages > 1)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;border-top:1px solid var(--border)">
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasPreviousPage)" @onclick="PrevPage">Previous</button>
                <span style="font-size:.85rem;color:var(--text-muted)">Page @_pagedResult.Page of @_pagedResult.TotalPages</span>
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasNextPage)" @onclick="NextPage">Next</button>
            </div>
        }
    </div>
}

@if (_showCreate)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;display:flex;align-items:center;justify-content:center">
        <div class="card" style="width:460px;max-width:95vw">
            <div class="card-header-custom">
                <span class="card-title-custom">New Sales Order</span>
                <button class="btn-logout" @onclick="() => _showCreate = false">&#x2715;</button>
            </div>
            <div class="card-body-custom">
                @if (!string.IsNullOrEmpty(_createError))
                {
                    <div class="alert-custom alert-error">&#9888; @_createError</div>
                }
                <div class="form-group">
                    <label class="form-label">Customer</label>
                    <select class="form-control-custom" @bind="_newItem.CustomerId">
                        <option value="@Guid.Empty">-- Select Customer --</option>
                        @if (_customers != null)
                        {
                            @foreach (var c in _customers.Items)
                            {
                                <option value="@c.Id">@c.Name (@c.CustomerCode)</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Notes</label>
                    <input class="form-control-custom" @bind="_newItem.Notes" placeholder="Optional notes" />
                </div>
                <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem">
                    <button class="btn-outline" @onclick="() => _showCreate = false">Cancel</button>
                    <button class="btn-primary-custom" @onclick="CreateAsync" disabled="@_creating">
                        @if (_creating) { <span class="spinner" style="border-top-color:#fff"></span> }
                        Create
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _showCreate;
    private bool _creating;
    private string _createError = string.Empty;
    private string _search = string.Empty;
    private int _page = 1;
    private int _pageSize = 20;
    private PagedResult<SalesOrderDto>? _pagedResult;
    private PagedResult<CustomerDto>? _customers;
    private readonly CreateSalesOrderRequest _newItem = new();

    protected override async Task OnInitializedAsync()
    {
        try { _customers = await Api.GetCustomersAsync(1, 100, null); } catch { }
        await LoadDataAsync();
        _loading = false;
    }

    private async Task LoadDataAsync()
    {
        try { _pagedResult = await Api.GetSalesOrdersAsync(_page, _pageSize, _search); } catch { }
    }

    private async Task SearchAsync()
    {
        _page = 1;
        await LoadDataAsync();
    }

    private async Task HandleSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    private async Task PrevPage() { _page--; await LoadDataAsync(); }
    private async Task NextPage() { _page++; await LoadDataAsync(); }

    private async Task CreateAsync()
    {
        _creating = true;
        _createError = string.Empty;

        var result = await Api.CreateSalesOrderAsync(_newItem);
        if (result != null)
        {
            _showCreate = false;
            _page = 1;
            await LoadDataAsync();
        }
        else
        {
            _createError = "Failed to create sales order.";
        }

        _creating = false;
    }

    private static string StatusClass(string s) => "status-" + s.ToLower().Replace(" ", "");
}
