@page "/attendance"
@layout AppLayout

@inject ApiClient Api
@inject AuthService AuthSvc

<PageTitle>Attendance — NiagaOne</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Attendance</h1>
        <div class="page-sub">Track employee attendance and working hours</div>
    </div>
    <div style="display:flex;gap:.5rem">
        <button class="btn-primary-custom" @onclick="ClockInAsync" disabled="@_clocking">
            @if (_clocking) { <span class="spinner" style="border-top-color:#fff"></span> }
            Clock In
        </button>
        <button class="btn-outline" @onclick="ClockOutAsync" disabled="@_clocking">
            Clock Out
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_actionMsg))
{
    <div class="alert-custom @(_actionSuccess ? "alert-success" : "alert-error")" style="margin-bottom:1rem">
        @_actionMsg
    </div>
}

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading attendance...</div>
}
else
{
    <div class="card">
        <div style="padding:.75rem 1rem;display:flex;gap:.75rem;align-items:center">
            <input class="form-control-custom" placeholder="Search by employee..." @bind="_search" @bind:event="oninput" @onkeydown="HandleSearchKey" style="max-width:300px" />
            <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" @onclick="SearchAsync">Search</button>
        </div>
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Date</th>
                        <th>Clock In</th>
                        <th>Clock Out</th>
                        <th>Hours</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_pagedResult == null || !_pagedResult.Items.Any())
                    {
                        <tr><td colspan="5">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#128340;</div>
                                <div class="empty-state-text">No attendance records found.</div>
                            </div>
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var a in _pagedResult.Items)
                        {
                            <tr>
                                <td><strong>@a.EmployeeName</strong></td>
                                <td>@a.Date.ToString("MMM d, yyyy")</td>
                                <td>@(a.ClockIn?.ToString("HH:mm") ?? "—")</td>
                                <td>@(a.ClockOut?.ToString("HH:mm") ?? "—")</td>
                                <td>@(a.WorkingHours?.ToString("F1") ?? "—")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (_pagedResult != null && _pagedResult.TotalPages > 1)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;border-top:1px solid var(--border)">
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasPreviousPage)" @onclick="PrevPage">Previous</button>
                <span style="font-size:.85rem;color:var(--text-muted)">Page @_pagedResult.Page of @_pagedResult.TotalPages</span>
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasNextPage)" @onclick="NextPage">Next</button>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private bool _clocking;
    private string _actionMsg = string.Empty;
    private bool _actionSuccess;
    private string _search = string.Empty;
    private int _page = 1;
    private int _pageSize = 20;
    private PagedResult<AttendanceDto>? _pagedResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        _loading = false;
    }

    private async Task LoadDataAsync()
    {
        try { _pagedResult = await Api.GetAttendanceAsync(_page, _pageSize, _search); } catch { }
    }

    private async Task SearchAsync() { _page = 1; await LoadDataAsync(); }
    private async Task HandleSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") await SearchAsync(); }
    private async Task PrevPage() { _page--; await LoadDataAsync(); }
    private async Task NextPage() { _page++; await LoadDataAsync(); }

    private async Task ClockInAsync()
    {
        _clocking = true;
        _actionMsg = string.Empty;

        var ok = await Api.ClockInAsync();
        _actionSuccess = ok;
        _actionMsg = ok ? "Clocked in successfully." : "Failed to clock in. You may have already clocked in today.";

        if (ok) await LoadDataAsync();
        _clocking = false;
    }

    private async Task ClockOutAsync()
    {
        _clocking = true;
        _actionMsg = string.Empty;

        var ok = await Api.ClockOutAsync();
        _actionSuccess = ok;
        _actionMsg = ok ? "Clocked out successfully." : "Failed to clock out. You may need to clock in first.";

        if (ok) await LoadDataAsync();
        _clocking = false;
    }
}
