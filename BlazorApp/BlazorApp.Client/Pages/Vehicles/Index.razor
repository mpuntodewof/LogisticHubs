@page "/vehicles"
@layout AppLayout

@inject ApiClient Api
@inject NavigationManager Nav
@inject AuthService AuthSvc

<PageTitle>Vehicles — NiagaOne</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Vehicles</h1>
        <div class="page-sub">Fleet vehicle registry</div>
    </div>
    <button class="btn-primary-custom" @onclick="OpenCreate">
        &#43; New Vehicle
    </button>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading vehicles...</div>
}
else
{
    <div class="card">
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Plate Number</th>
                        <th>Type</th>
                        <th>Capacity (kg)</th>
                        <th>Volume (m³)</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_vehicles.Any())
                    {
                        <tr><td colspan="6">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#128663;</div>
                                <div class="empty-state-text">No vehicles registered yet.</div>
                            </div>
                        </td></tr>
                    }
                    @foreach (var v in _vehicles)
                    {
                        <tr>
                            <td><strong>@v.PlateNumber</strong></td>
                            <td>@v.VehicleType</td>
                            <td>@v.CapacityWeight.ToString("F0")</td>
                            <td>@v.CapacityVolume.ToString("F1")</td>
                            <td><span class="badge-status @StatusClass(v.Status)">@v.Status</span></td>
                            <td>
                                <div style="display:flex;gap:.4rem;justify-content:flex-end">
                                    <button class="btn-outline" style="padding:.3rem .7rem;font-size:.75rem" @onclick="@(() => OpenEdit(v))">Edit</button>
                                    <button class="btn-outline" style="padding:.3rem .7rem;font-size:.75rem;color:#ef4444;border-color:#ef4444" @onclick="@(() => ConfirmDelete(v))">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* ── Create / Edit Dialog ── *@
@if (_showForm)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;display:flex;align-items:center;justify-content:center">
        <div class="card" style="width:480px;max-width:95vw">
            <div class="card-header-custom">
                <span class="card-title-custom">@(_isEdit ? "Edit Vehicle" : "New Vehicle")</span>
                <button class="btn-logout" @onclick="CloseForm">&#x2715;</button>
            </div>
            <div class="card-body-custom">
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="alert-custom alert-error">&#9888; @_formError</div>
                }
                @if (!_isEdit)
                {
                    <div class="form-group">
                        <label class="form-label">Plate Number</label>
                        <input class="form-control-custom" @bind="_createReq.PlateNumber" placeholder="AB-1234-CD" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Vehicle Type</label>
                        <select class="form-control-custom" @bind="_createReq.VehicleType">
                            <option value="">-- Select Type --</option>
                            <option value="Truck">Truck</option>
                            <option value="Van">Van</option>
                            <option value="Motorcycle">Motorcycle</option>
                            <option value="Trailer">Trailer</option>
                        </select>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">
                        <div class="form-group">
                            <label class="form-label">Capacity (kg)</label>
                            <input class="form-control-custom" type="number" @bind="_createReq.CapacityWeight" placeholder="0" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Volume (m³)</label>
                            <input class="form-control-custom" type="number" @bind="_createReq.CapacityVolume" placeholder="0.0" />
                        </div>
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label class="form-label">Vehicle Type</label>
                        <select class="form-control-custom" @bind="_updateReq.VehicleType">
                            <option value="">-- Select Type --</option>
                            <option value="Truck">Truck</option>
                            <option value="Van">Van</option>
                            <option value="Motorcycle">Motorcycle</option>
                            <option value="Trailer">Trailer</option>
                        </select>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">
                        <div class="form-group">
                            <label class="form-label">Capacity (kg)</label>
                            <input class="form-control-custom" type="number" @bind="_editCapWeight" placeholder="0" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Volume (m³)</label>
                            <input class="form-control-custom" type="number" @bind="_editCapVolume" placeholder="0.0" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <select class="form-control-custom" @bind="_updateReq.Status">
                            <option value="Available">Available</option>
                            <option value="InUse">In Use</option>
                            <option value="Maintenance">Maintenance</option>
                            <option value="Retired">Retired</option>
                        </select>
                    </div>
                }
                <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem">
                    <button class="btn-outline" @onclick="CloseForm">Cancel</button>
                    <button class="btn-primary-custom" @onclick="SaveAsync" disabled="@_saving">
                        @if (_saving) { <span class="spinner" style="border-top-color:#fff"></span> }
                        @(_isEdit ? "Update" : "Create")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Delete Confirmation ── *@
@if (_showDelete)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;display:flex;align-items:center;justify-content:center">
        <div class="card" style="width:400px;max-width:95vw">
            <div class="card-header-custom">
                <span class="card-title-custom">Confirm Delete</span>
                <button class="btn-logout" @onclick="() => _showDelete = false">&#x2715;</button>
            </div>
            <div class="card-body-custom">
                <p>Are you sure you want to delete vehicle <strong>@_deleteTarget?.PlateNumber</strong>?</p>
                <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem">
                    <button class="btn-outline" @onclick="() => _showDelete = false">Cancel</button>
                    <button class="btn-primary-custom" style="background:#ef4444" @onclick="DeleteAsync" disabled="@_saving">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _showForm;
    private bool _showDelete;
    private bool _isEdit;
    private bool _saving;
    private string _formError = string.Empty;
    private List<VehicleDto> _vehicles = new();
    private CreateVehicleRequest _createReq = new();
    private UpdateVehicleRequest _updateReq = new();
    private decimal _editCapWeight;
    private decimal _editCapVolume;
    private VehicleDto? _editTarget;
    private VehicleDto? _deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        try { _vehicles = await Api.GetVehiclesAsync(); } catch { }
        _loading = false;
    }

    private void OpenCreate()
    {
        _isEdit = false;
        _createReq = new();
        _formError = string.Empty;
        _showForm = true;
    }

    private void OpenEdit(VehicleDto v)
    {
        _isEdit = true;
        _editTarget = v;
        _editCapWeight = v.CapacityWeight;
        _editCapVolume = v.CapacityVolume;
        _updateReq = new() { VehicleType = v.VehicleType, Status = v.Status };
        _formError = string.Empty;
        _showForm = true;
    }

    private void CloseForm() => _showForm = false;

    private async Task SaveAsync()
    {
        _saving = true;
        _formError = string.Empty;

        if (_isEdit && _editTarget != null)
        {
            _updateReq.CapacityWeight = _editCapWeight;
            _updateReq.CapacityVolume = _editCapVolume;
            var ok = await Api.UpdateVehicleAsync(_editTarget.Id, _updateReq);
            if (ok)
            {
                _editTarget.VehicleType = _updateReq.VehicleType ?? _editTarget.VehicleType;
                _editTarget.CapacityWeight = _editCapWeight;
                _editTarget.CapacityVolume = _editCapVolume;
                _editTarget.Status = _updateReq.Status ?? _editTarget.Status;
                _showForm = false;
            }
            else _formError = "Failed to update vehicle.";
        }
        else
        {
            var result = await Api.CreateVehicleAsync(_createReq);
            if (result != null) { _vehicles.Insert(0, result); _showForm = false; }
            else _formError = "Failed to create vehicle. Check plate number.";
        }

        _saving = false;
    }

    private void ConfirmDelete(VehicleDto v) { _deleteTarget = v; _showDelete = true; }

    private async Task DeleteAsync()
    {
        if (_deleteTarget == null) return;
        _saving = true;
        var ok = await Api.DeleteVehicleAsync(_deleteTarget.Id);
        if (ok) _vehicles.Remove(_deleteTarget);
        _showDelete = false;
        _saving = false;
    }

    private static string StatusClass(string s) => "status-" + s.ToLower().Replace(" ", "");
}
