@page "/products"
@layout AppLayout

@inject ApiClient Api
@inject NavigationManager Nav
@inject AuthService AuthSvc

<PageTitle>Products — NiagaOne</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Products</h1>
        <div class="page-sub">Product catalog management</div>
    </div>
    <button class="btn-primary-custom" @onclick="() => _showCreate = true">
        &#43; New Product
    </button>
</div>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div> Loading products...</div>
}
else
{
    <div class="card">
        <div style="padding:.75rem 1rem;display:flex;gap:.75rem;align-items:center">
            <input class="form-control-custom" placeholder="Search products..." @bind="_search" @bind:event="oninput" @onkeydown="HandleSearchKey" style="max-width:300px" />
            <button class="btn-outline" style="padding:.4rem .8rem;font-size:.8rem" @onclick="SearchAsync">Search</button>
        </div>
        <div class="table-wrapper">
            <table class="lh-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Brand</th>
                        <th>Status</th>
                        <th>Variants</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_pagedResult == null || !_pagedResult.Items.Any())
                    {
                        <tr><td colspan="6">
                            <div class="empty-state">
                                <div class="empty-state-icon">&#128230;</div>
                                <div class="empty-state-text">No products found.</div>
                            </div>
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var p in _pagedResult.Items)
                        {
                            <tr>
                                <td><strong>@p.Name</strong></td>
                                <td>@p.CategoryName</td>
                                <td>@(p.BrandName ?? "—")</td>
                                <td><span class="badge-status @StatusClass(p.Status)">@p.Status</span></td>
                                <td>@p.VariantCount</td>
                                <td>@p.CreatedAt.ToString("MMM d, yyyy")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (_pagedResult != null && _pagedResult.TotalPages > 1)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;border-top:1px solid var(--border)">
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasPreviousPage)" @onclick="PrevPage">Previous</button>
                <span style="font-size:.85rem;color:var(--text-muted)">Page @_pagedResult.Page of @_pagedResult.TotalPages</span>
                <button class="btn-outline" style="padding:.3rem .7rem;font-size:.8rem" disabled="@(!_pagedResult.HasNextPage)" @onclick="NextPage">Next</button>
            </div>
        }
    </div>
}

@if (_showCreate)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;display:flex;align-items:center;justify-content:center">
        <div class="card" style="width:460px;max-width:95vw">
            <div class="card-header-custom">
                <span class="card-title-custom">New Product</span>
                <button class="btn-logout" @onclick="() => _showCreate = false">&#x2715;</button>
            </div>
            <div class="card-body-custom">
                @if (!string.IsNullOrEmpty(_createError))
                {
                    <div class="alert-custom alert-error">&#9888; @_createError</div>
                }
                <div class="form-group">
                    <label class="form-label">Name</label>
                    <input class="form-control-custom" @bind="_newItem.Name" placeholder="Product name" />
                </div>
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <input class="form-control-custom" @bind="_newItem.Description" placeholder="Optional description" />
                </div>
                <div class="form-group">
                    <label class="form-label">Category</label>
                    <select class="form-control-custom" @bind="_newItem.CategoryId">
                        <option value="@Guid.Empty">-- Select Category --</option>
                        @if (_categories != null)
                        {
                            @foreach (var c in _categories.Items)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Brand</label>
                    <select class="form-control-custom" @bind="_newItem.BrandId">
                        <option value="">-- None --</option>
                        @if (_brands != null)
                        {
                            @foreach (var b in _brands.Items)
                            {
                                <option value="@b.Id">@b.Name</option>
                            }
                        }
                    </select>
                </div>
                <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem">
                    <button class="btn-outline" @onclick="() => _showCreate = false">Cancel</button>
                    <button class="btn-primary-custom" @onclick="CreateAsync" disabled="@_creating">
                        @if (_creating) { <span class="spinner" style="border-top-color:#fff"></span> }
                        Create
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _showCreate;
    private bool _creating;
    private string _createError = string.Empty;
    private string _search = string.Empty;
    private int _page = 1;
    private int _pageSize = 20;
    private PagedResult<ProductDto>? _pagedResult;
    private PagedResult<CategoryDto>? _categories;
    private PagedResult<BrandDto>? _brands;
    private readonly CreateProductRequest _newItem = new();

    protected override async Task OnInitializedAsync()
    {
        var catResult = await Api.GetCategoriesAsync(1, 100, null); if (catResult.Success) _categories = catResult.Data;
        var brdResult = await Api.GetBrandsAsync(1, 100, null); if (brdResult.Success) _brands = brdResult.Data;
        await LoadDataAsync();
        _loading = false;
    }

    private async Task LoadDataAsync()
    {
        var apiResult = await Api.GetProductsAsync(_page, _pageSize, _search); if (apiResult.Success) _pagedResult = apiResult.Data;
    }

    private async Task SearchAsync()
    {
        _page = 1;
        await LoadDataAsync();
    }

    private async Task HandleSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    private async Task PrevPage() { _page--; await LoadDataAsync(); }
    private async Task NextPage() { _page++; await LoadDataAsync(); }

    private async Task CreateAsync()
    {
        _creating = true;
        _createError = string.Empty;

        var result = await Api.CreateProductAsync(_newItem);
        if (result.Success && result.Data != null)
        {
            _showCreate = false;
            _page = 1;
            await LoadDataAsync();
        }
        else
        {
            _createError = result.ErrorMessage ?? "Failed to create product.";
        }

        _creating = false;
    }

    private static string StatusClass(string s) => "status-" + s.ToLower().Replace(" ", "");
}
